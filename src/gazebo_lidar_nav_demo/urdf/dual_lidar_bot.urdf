<?xml version="1.0"?>
<robot name="dual_lidar_bot">
  <material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="blue"><color rgba="0.1 0.3 0.9 1.0"/></material>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="8.0"/>
      <inertia ixx="0.25" ixy="0.0" ixz="0.0" iyy="0.25" iyz="0.0" izz="0.35"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.12"/>
      <geometry><box size="0.45 0.35 0.12"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.12"/>
      <geometry><box size="0.45 0.35 0.12"/></geometry>
    </collision>
  </link>

  <link name="left_wheel_link">
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.0015"/>
    </inertial>
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
    </collision>
  </link>

  <link name="right_wheel_link">
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.0015"/>
    </inertial>
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 0.185 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -0.185 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="caster_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.18 0 0.03"/>
  </joint>

  <link name="lidar_2d_link">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.03" length="0.05"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.03" length="0.05"/></geometry>
    </collision>
  </link>

  <joint name="lidar_2d_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_2d_link"/>
    <origin xyz="0.12 0 0.22"/>
  </joint>

  <link name="lidar_3d_link">
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
    </collision>
  </link>

  <joint name="lidar_3d_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_3d_link"/>
    <origin xyz="-0.02 0 0.26"/>
  </joint>

  <gazebo>
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.37</wheel_separation>
      <wheel_diameter>0.16</wheel_diameter>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <cmd_vel_topic>cmd_vel</cmd_vel_topic>
      <odometry_topic>odom</odometry_topic>
      <max_wheel_torque>12</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_2d_link">
    <sensor name="scan_2d" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>12</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="gazebo_ros_2d_laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_2d_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_3d_link">
    <sensor name="scan_3d" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1024</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.26</min_angle>
            <max_angle>0.26</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.2</min>
          <max>40.0</max>
          <resolution>0.02</resolution>
        </range>
      </ray>
      <plugin name="gazebo_ros_3d_laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=points2</remapping>
        </ros>
        <output_type>sensor_msgs/PointCloud2</output_type>
        <frame_name>lidar_3d_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
</robot>
